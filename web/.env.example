# Sao chép file này thành .env và điền giá trị thật khi deploy (spec.md mục 16.4).
# Không commit file .env thật lên Git.

# Chuỗi bí mật để ký session admin — đổi giá trị ngẫu nhiên khác cho production.
# BẮT BUỘC tối thiểu 32 ký tự (yêu cầu của iron-webcrypto qua h3 useSession) —
# để trống thì nuxt.config.ts tự dùng chuỗi mặc định chỉ đủ cho dev cá nhân.
ADMIN_SESSION_SECRET=

# Để trống sẽ tự dùng ../data và ../uploads so với thư mục web/ (đúng cấu trúc mục 14.1)
# Chỉ set khi deploy có cấu trúc thư mục khác
DATA_DIR=
UPLOADS_DIR=

# Cổng server lắng nghe khi chạy production (node .output/server/index.mjs).
# Để trống sẽ mặc định 3000.
PORT=3000
